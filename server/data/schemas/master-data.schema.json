{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gogyo-tenrin.invalid/schema/master-data.schema.json",
  "title": "五行転輪 実装用マスターデータ",
  "type": "object",
  "required": [
    "cards",
    "cardTemplates",
    "shikigami",
    "barriers",
    "terrains",
    "forbiddenArts",
    "keywords",
    "curses",
    "aiScores"
  ],
  "additionalProperties": false,
  "properties": {
    "cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/card"
      }
    },
    "cardTemplates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/template"
      }
    },
    "shikigami": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shikigami"
      }
    },
    "barriers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/namedMaster"
      }
    },
    "terrains": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/namedMaster"
      }
    },
    "forbiddenArts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/forbiddenArt"
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/namedMaster"
      }
    },
    "curses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/namedMaster"
      }
    },
    "aiScores": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/aiScore"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "effect": {
      "type": "object",
      "required": [
        "type",
        "cardId"
      ],
      "properties": {
        "type": {
          "enum": [
            "attack",
            "turn",
            "summon",
            "defense",
            "barrier",
            "terrain"
          ]
        },
        "cardId": {
          "$ref": "#/$defs/id"
        }
      },
      "additionalProperties": true
    },
    "card": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "system",
        "attribute",
        "cost",
        "mpCost",
        "weight",
        "target",
        "timing",
        "timings",
        "effects",
        "effectText",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "templateId": {
          "anyOf": [
            {
              "$ref": "#/$defs/id"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "system": {
          "type": "string",
          "minLength": 1
        },
        "attribute": {
          "type": "string",
          "minLength": 1
        },
        "cost": {
          "type": "number",
          "minimum": 0
        },
        "mpCost": {
          "type": "number",
          "minimum": 0
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "timing": {
          "type": "string",
          "minLength": 1
        },
        "timings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "effectText": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "imageId": {
          "type": [
            "string",
            "null"
          ]
        },
        "animationId": {
          "type": [
            "string",
            "null"
          ]
        },
        "soundId": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "template": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "system",
        "imageId",
        "description",
        "hasAttributeVariants"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "system": {
          "type": "string",
          "minLength": 1
        },
        "imageId": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "hasAttributeVariants": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "shikigami": {
      "type": "object",
      "required": [
        "id",
        "name",
        "attribute",
        "maxHp",
        "attack",
        "aiProfile",
        "keywordIds",
        "ability",
        "description",
        "imageId"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "attribute": {
          "type": "string",
          "minLength": 1
        },
        "maxHp": {
          "type": "number",
          "minimum": 1
        },
        "attack": {
          "type": "number",
          "minimum": 0
        },
        "aiProfile": {
          "type": "string",
          "minLength": 1
        },
        "keywordIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "ability": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "imageId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "namedMaster": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "forbiddenArt": {
      "allOf": [
        {
          "$ref": "#/$defs/namedMaster"
        },
        {
          "type": "object",
          "required": [
            "cost",
            "mpCost",
            "weight"
          ],
          "properties": {
            "cost": {
              "type": "number",
              "minimum": 0
            },
            "mpCost": {
              "type": "number",
              "minimum": 0
            },
            "weight": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      ]
    },
    "aiScore": {
      "type": "object",
      "required": [
        "id",
        "target",
        "score",
        "notes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  }
}
